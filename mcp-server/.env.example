# Supabase (same project as the site)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # bypasses RLS; server-only, never ship to the browser

# Google Gemini API key for embeddings (free tier, no card): https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Public HTTPS URL this MCP server is reachable at (its own Vercel project).
# The server acts as its own OAuth Authorization Server + Resource Server.
MNEMOS_MCP_URL=https://mnemos-server.vercel.app

# Public URL of the Next.js site (used for the browser leg of OAuth login).
MNEMOS_SITE_URL=https://mnemos-mcp.vercel.app

# Local only: port `python server.py` listens on. Vercel ignores this.
PORT=8000
